# Gemini AI API Key
# https://aistudio.google.com/app/apikey adresinden alın
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Project ID
FIREBASE_PROJECT_ID=nefes-app-XXXXX

# AdMob IDs (test modunda bırakın geliştirme sırasında)
